# Supabase client-safe values. These are public browser config, not secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this through NEXT_PUBLIC_ variables or client code.
SUPABASE_SERVICE_ROLE_KEY=

# App URL. NEXT_PUBLIC_* values are baked at build time on Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000
